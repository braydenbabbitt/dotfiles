#!/usr/bin/env bash
# tether-status — list active plans for crash-recoverable work.
#
# Part of the agent-workflows / tether protocol:
#   ~/.config/agent-workflows/tether/PROTOCOL.md
#
# Agent-agnostic: prints active plan documents (with their in-progress phase) and any
# outstanding TODO(plan:...) code markers, so any coding agent (or human) resuming
# a session can pick up exactly where work stopped. A plan in phase 1 has no code
# markers yet — it exists only as a .plans/<name>.md document, so both are scanned.
# Always exits 0 so it is safe to wire into editor/agent session-start hooks.
#
# Parallel-session safe: several sessions may share one checkout, so the plans and
# markers listed here can belong to OTHER active sessions. This tool only REPORTS
# them — it does not imply the current session should resume any of them. The
# emitted directive tells the agent to resume a plan only when the user's request
# matches it, and otherwise to start fresh under a new <name> (see PROTOCOL.md).
#
# Usage:
#   tether-status [path]   # path defaults to the current git repo root, else cwd

set -uo pipefail

root="${1:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
plans_dir="$root/.plans"

# --- Plan documents (the source of truth for phase) -------------------------
plan_docs=""
if [ -d "$plans_dir" ]; then
  plan_docs="$(find "$plans_dir" -maxdepth 1 -type f -name '*.md' 2>/dev/null | sort || true)"
fi

# --- Code markers (phases 2-3) ----------------------------------------------
if command -v rg >/dev/null 2>&1; then
  # ripgrep respects .gitignore, so build artifacts/deps are skipped automatically.
  matches="$(rg --no-heading --line-number --color never 'TODO\(plan:' "$root" 2>/dev/null || true)"
else
  matches="$(grep -rn \
    --exclude-dir=.git \
    --exclude-dir=node_modules \
    --exclude-dir=dist \
    --exclude-dir=build \
    --exclude-dir=.next \
    --exclude-dir=.turbo \
    'TODO(plan:' "$root" 2>/dev/null || true)"
fi

# Path to the protocol doc the coding agent must follow. Resolved for the directive
# only — printed even when the file is elsewhere, as a pointer.
protocol="$HOME/.config/agent-workflows/tether/PROTOCOL.md"

if [ -z "$plan_docs" ] && [ -z "$matches" ]; then
  echo "tether-status: no in-progress plans (no .plans/*.md documents or TODO(plan:...) markers found)."
  echo
  echo "DIRECTIVE (coding agent, every session — non-optional): this project follows the"
  echo "tether protocol at $protocol."
  echo "There is nothing to resume right now. When you begin any task that spans more than a"
  echo "single edit, you MUST start at Phase 1 (create .plans/<name>.md) and advance through"
  echo "the phases, pausing for user confirmation at each phase gate."
  exit 0
fi

echo "tether-status: in-progress work found (possibly owned by other parallel sessions)."
echo
echo "DIRECTIVE (coding agent, every session — non-optional): this project follows the"
echo "tether protocol at $protocol."
echo "The plans and markers below may belong to OTHER sessions still working on them."
echo "Do NOT resume a plan just because it is in progress. Run the protocol's Recovery"
echo "steps: resume a plan ONLY if the user's request for this session matches it (named"
echo "explicitly, or the same work it describes). If none matches, leave every plan and"
echo "its markers untouched and start new work at Phase 1 under a new <name>. When unsure"
echo "whether a plan is yours to touch, ask the user rather than adopting it."

if [ -n "$plan_docs" ]; then
  echo
  echo "Active plans:"
  while IFS= read -r doc; do
    [ -z "$doc" ] && continue
    name="$(basename "$doc" .md)"
    # The in-progress phase is the checklist line marked '[-]'. If none is marked
    # in progress, the first incomplete '[ ]' line is the next phase to start.
    phase="$(grep -m1 -E '^- \[-\] ' "$doc" 2>/dev/null \
      | sed -E 's/^- \[-\] *//' || true)"
    if [ -n "$phase" ]; then
      echo "  - $name — phase: $phase  ($doc)"
    else
      next="$(grep -m1 -E '^- \[ \] ' "$doc" 2>/dev/null \
        | sed -E 's/^- \[ \] *//' || true)"
      if [ -n "$next" ]; then
        echo "  - $name — next phase to start: $next  ($doc)"
      else
        echo "  - $name — phase: (no [-] or [ ] box found)  ($doc)"
      fi
    fi
  done <<< "$plan_docs"
fi

if [ -n "$matches" ]; then
  echo
  echo "Outstanding TODO(plan:...) code markers (phases 2-3):"
  echo "$matches"
fi
exit 0
