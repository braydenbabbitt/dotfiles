#!/usr/bin/env bash
# plan-status — list outstanding TODO(plan:...) markers for crash-recoverable work.
#
# Part of the agent-workflows / plan-persistence protocol:
#   ~/.config/agent-workflows/plan-persistence/PROTOCOL.md
#
# Agent-agnostic: prints active plans and their checklist state so any coding
# agent (or human) resuming a session can pick up exactly where work stopped.
# Always exits 0 so it is safe to wire into editor/agent session-start hooks.
#
# Usage:
#   plan-status [path]   # path defaults to the current git repo root, else cwd

set -uo pipefail

root="${1:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"

if command -v rg >/dev/null 2>&1; then
  # ripgrep respects .gitignore, so build artifacts/deps are skipped automatically.
  matches="$(rg --no-heading --line-number --color never 'TODO\(plan:' "$root" 2>/dev/null || true)"
else
  matches="$(grep -rn \
    --exclude-dir=.git \
    --exclude-dir=node_modules \
    --exclude-dir=dist \
    --exclude-dir=build \
    --exclude-dir=.next \
    --exclude-dir=.turbo \
    'TODO(plan:' "$root" 2>/dev/null || true)"
fi

if [ -z "$matches" ]; then
  echo "plan-status: no in-progress plans (no TODO(plan:...) markers found)."
  exit 0
fi

echo "plan-status: in-progress plans found. Resume each from its first '[ ]' step (look for '<-- next')."
echo "Active plans:"
# Pull distinct plan names out of the marker for a quick summary header.
echo "$matches" \
  | grep -oE 'TODO\(plan:[^)]+\)' \
  | sed -E 's/TODO\(plan:(.*)\)/  - \1/' \
  | sort -u
echo
echo "Markers:"
echo "$matches"
exit 0
