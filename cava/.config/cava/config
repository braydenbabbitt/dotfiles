# cava config for the waybar audio visualizer module.
# Driven by hypr/.config/hypr/scripts/cava-waybar.sh, which reads the raw
# ascii stream and maps each bar value (0..7) to a block glyph.

[general]
framerate = 30
# Number of bars in the visualizer.
bars = 18
autosens = 1
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
# PipeWire system: cava's pulse backend works through pipewire-pulse and
# captures the monitor of the default output sink, so the bars react to
# whatever is playing through system audio.
method = pulse
source = auto

[output]
method = raw
raw_target = /dev/stdout
data_format = ascii
# Each bar value is an integer 0..7 -> maps cleanly onto 8 block glyphs.
ascii_max_range = 7
channels = mono
# Defaults: bar_delimiter = 59 (';'), frame_delimiter = 10 ('\n').
